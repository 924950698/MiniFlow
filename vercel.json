{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/kimi/chat.ts": { "maxDuration": 60 },
    "api/notify.ts": { "maxDuration": 10 }
  }
}
